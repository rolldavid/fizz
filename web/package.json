{
  "name": "fizz-web",
  "version": "0.1.0",
  "description": "fizzwallet.com — a single-page Vite + React app (home, /bridge, /launch). Builds into web/dist (with per-route SEO shells); served on Railway.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc",
    "build": "tsc && vite build && node ./scripts/postbuild.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.59.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^6.28.0",
    "viem": "2.51.3",
    "wagmi": "^2.14.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.279",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-node-polyfills": "^0.22.0"
  },
  "engines": {
    "node": ">=22"
  }
}
