{
  "name": "fizz-wallet",
  "version": "0.1.3",
  "description": "Fizz — dark-mode Aztec network browser-extension wallet. Private + public balances, in-browser PXE, passkey or mnemonic unlock.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:all": "vitest run",
    "test:pw": "playwright test",
    "test:pw:headless": "PW_HEADLESS=1 playwright test",
    "test:pw:ui": "playwright test --ui",
    "test:pw:network": "PW_NETWORK=1 playwright test",
    "test:pw:funded": "playwright test funded",
    "test:pw:report": "playwright show-report",
    "verify": "yarn install --frozen-lockfile && yarn typecheck && yarn test && yarn build",
    "package": "yarn verify && cd dist && zip -rq ../aztec-wallet-$npm_package_version.zip . && cd .. && echo \"Packaged: aztec-wallet-$npm_package_version.zip\"",
    "package:store": "yarn verify && node scripts/strip-manifest-key.mjs && cd dist && zip -rq ../fizz-webstore-$npm_package_version.zip . && cd .. && echo \"Packaged for the Web Store (no key): fizz-webstore-$npm_package_version.zip\"",
    "postinstall": "patch-package --error-on-fail"
  },
  "dependencies": {
    "@aztec/accounts": "4.3.0",
    "@aztec/aztec.js": "4.3.0",
    "@aztec/constants": "4.3.0",
    "@aztec/entrypoints": "4.3.0",
    "@aztec/foundation": "4.3.0",
    "@aztec/kv-store": "4.3.0",
    "@aztec/noir-contracts.js": "4.3.0",
    "@aztec/pxe": "4.3.0",
    "@aztec/stdlib": "4.3.0",
    "@aztec/wallet-sdk": "4.3.0",
    "@aztec/wallets": "4.3.0",
    "@noble/hashes": "1.8.0",
    "@scure/bip39": "1.6.0",
    "qrcode": "1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "viem": "2.51.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@playwright/test": "1.61.0",
    "@types/chrome": "0.0.279",
    "@types/qrcode": "1.5.6",
    "@types/react": "18.3.29",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react-swc": "3.11.0",
    "fast-check": "3.23.2",
    "patch-package": "8.0.1",
    "puppeteer-core": "25.1.0",
    "typescript": "5.6.3",
    "vite": "5.4.21",
    "vite-plugin-node-polyfills": "0.22.0",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
